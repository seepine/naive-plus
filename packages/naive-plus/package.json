{
  "name": "naive-plus",
  "version": "0.1.0-beta.2",
  "description": "基于 Vue3 和 NaiveUI 的组件库",
  "main": "lib/index.js",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "style": "dist/index.css",
  "unpkg": "dist/index.min.js",
  "jsdelivr": "dist/index.min.js",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.js"
    },
    "./resolver": {
      "types": "./es/resolver.d.ts",
      "import": "./es/resolver.mjs",
      "require": "./lib/resolver.js"
    },
    "./index.css": "./dist/index.css",
    "./index.scss": "./es/index.scss",
    "./package.json": "./package.json"
  },
  "scripts": {
    "gen": "tsx scripts/generate/component.ts",
    "build": "gulp --require @esbuild-kit/cjs-loader -f scripts/build/index.ts",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "es",
    "lib",
    "dist",
    "global.d.ts"
  ],
  "keywords": [
    "naive",
    "naive-plus",
    "naive-ui",
    "vue",
    "vue3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "naive-ui": "^2.43.0",
    "vue": "^3.2.0"
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@esbuild-kit/cjs-loader": "^2.4.2",
    "@rollup/plugin-commonjs": "^25.0.3",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@types/fs-extra": "^11.0.1",
    "@types/gulp": "^4.0.13",
    "@types/gulp-autoprefixer": "^0.0.34",
    "@types/gulp-clean-css": "^4.3.1",
    "@types/gulp-sass": "^5.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/prompts": "^2.4.4",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "@vitest/coverage-v8": "^0.33.0",
    "@vitest/ui": "^0.33.0",
    "@vue/test-utils": "^2.4.1",
    "components-helper": "^2.1.5",
    "esbuild": "^0.18.16",
    "execa": "^7.1.1",
    "fast-glob": "^3.3.1",
    "fs-extra": "^11.1.1",
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^8.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-sass": "^5.1.0",
    "happy-dom": "^10.5.2",
    "naive-ui": "^2.43.0",
    "prompts": "^2.4.2",
    "rollup": "^3.26.3",
    "rollup-plugin-esbuild": "^5.0.0",
    "sass": "^1.64.1",
    "tsx": "^4.8.1",
    "typescript": "^5.1.6",
    "unplugin-vue-components": "^0.25.1",
    "unplugin-vue-define-options": "^1.3.11",
    "vite": "^4.4.6",
    "vitest": "^0.33.0",
    "vue": "^3.3.4",
    "vue-tsc": "^1.8.6"
  },
  "sideEffects": [
    "dist/*",
    "es/**/*.css",
    "lib/**/*.scss",
    "es/**/style/*",
    "lib/**/style/*"
  ],
  "vetur": {
    "tags": "dist/tags.json",
    "attributes": "dist/attributes.json"
  },
  "web-types": "dist/web-types.json"
}
