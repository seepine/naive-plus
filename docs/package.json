{
  "name": "@seepine/docs",
  "private": true,
  "version": "0.1.0",
  "description": "基于 Vue3 和 Naive UI 的组件库",
  "scripts": {
    "docs:build": "vuepress build --clean-cache",
    "docs:clean": "rimraf .vuepress/.temp .vuepress/.cache .vuepress/dist",
    "docs:dev": "vuepress dev --clean-cache",
    "docs:serve": "anywhere -s -h localhost -d .vuepress/dist"
  },
  "devDependencies": {
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vuepress/bundler-vite": "2.0.0-rc.26",
    "@vuepress/cli": "2.0.0-rc.26",
    "@vuepress/client": "2.0.0-rc.26",
    "@vuepress/core": "2.0.0-rc.26",
    "@vuepress/markdown": "2.0.0-rc.26",
    "@vuepress/plugin-prismjs": "2.0.0-rc.21",
    "@vuepress/theme-default": "2.0.0-rc.26",
    "@vuepress/utils": "2.0.0-rc.26",
    "@vueuse/core": "^10.0.0",
    "anywhere": "^1.6.0",
    "naive-plus": "workspace:*",
    "naive-ui": "^2.43.0",
    "posthtml-parser": "^0.11.0",
    "posthtml-render": "^3.0.0",
    "rimraf": "^5.0.1",
    "sass-embedded": "^1.100.0",
    "tsx": "^4.8.1",
    "unplugin-vue-define-options": "^1.3.12",
    "vite": "~7.1.9",
    "vue": "^3.5.22",
    "vuepress": "2.0.0-rc.26",
    "@vuepress/plugin-llms": "2.0.0-rc.105"
  }
}
