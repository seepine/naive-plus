{
  "name": "@seepine/root",
  "private": true,
  "version": "0.1.0",
  "description": "基于 Vue3 和 NaiveUI 的组件库",
  "scripts": {
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "cz": "npx git-cz",
    "ui:gen": "pnpm --filter=naive-plus gen",
    "ui:build": "pnpm --filter=naive-plus build",
    "ui:type-check": "pnpm --filter=naive-plus type-check",
    "ui:test": "pnpm --filter=naive-plus test",
    "ui:test:ui": "pnpm --filter=naive-plus test:ui",
    "ui:test:coverage": "pnpm --filter=naive-plus test:coverage",
    "docs:dev": "pnpm --filter=docs docs:dev",
    "docs:clean": "pnpm --filter=docs docs:clean",
    "docs:build": "pnpm --filter=docs docs:build",
    "docs:serve": "pnpm --filter=docs docs:serve",
    "lint:lint-staged": "lint-staged",
    "lint:eslint": "eslint --fix --cache \"**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:stylelint": "stylelint --fix --cache \"**/*.{css,scss,less,styl,vue}\"",
    "lint:prettier": "prettier --write  \"**/*.{css,scss,less,styl,js,jsx,ts,tsx,vue}\"",
    "cs": "changeset",
    "cs:version": "changeset version",
    "cs:beta:enter": "changeset pre enter beta",
    "cs:beta:exit": "changeset pre exit",
    "release": "pnpm --recursive --stream build && changeset publish"
  },
  "dependencies": {
    "naive-plus": "workspace:*",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@seepine/eslint-config": "workspace:*",
    "@seepine/stylelint-config": "workspace:*",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^17.6.7",
    "@commitlint/config-conventional": "^17.6.7",
    "@vue/runtime-core": "^3.3.4",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.45.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "postcss": "^8.4.27",
    "prettier": "^3.0.0",
    "stylelint": "^15.10.2",
    "typescript": "^5.1.6",
    "unplugin-vue-define-options": "^1.3.11"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
